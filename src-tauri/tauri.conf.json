{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Any Auto Register",
  "version": "0.1.0",
  "identifier": "com.anyautoregister",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://127.0.0.1:8000"
  },
  "app": {
    "windows": [
      {
        "title": "Account Manager",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/backend"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
